    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@firebase/logger": "^0.5.1",
    "@sentry/angular": "^10.65.0",
    "angular-in-memory-web-api": "^0.22.0",
